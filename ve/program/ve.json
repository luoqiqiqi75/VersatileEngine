{
  "ve": {
    "entry": {
      "verbose": false,
      "plugins": []
    },
    "core": {
      "config": {
        "log": { "level": "info" }
      }
    },
    "client": {
      "terminal": {
        "stdio": {
          "enabled": false
        },
        "tcp": {
          "enabled": false,
          "config": {
            "host": "127.0.0.1",
            "port": 5061
          }
        }
      }
    },
    "server": {
      "priority": 50,
      "node": {
        "http": {
          "enable": true,
          "config": { "port": 5080 }
        },
        "ws": {
          "enable": true,
          "config": { "port": 5081 }
        },
        "tcp": {
          "enable": true,
          "config": { "port": 5082 }
        },
        "udp": {
          "enable": true,
          "config": { "port": 5083 }
        }
      },
      "terminal": {
        "repl": {
          "enable": true,
          "config": { "port": 5061 }
        }
      },
      "bin": {
        "tcp": {
          "enable": true,
          "config": { "port": 5065 }
        }
      }
    }
  }
