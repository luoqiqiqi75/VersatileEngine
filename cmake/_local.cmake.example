# =============================================================================
# _local.cmake — 本地开发配置（不提交到 Git）
# =============================================================================
# 复制本文件为 _local.cmake，根据你的机器环境修改：
#   cp cmake/_local.cmake.example cmake/_local.cmake
#
# 此文件在 .gitignore 中，任何 cmake/_*.cmake 都不会被提交。
# =============================================================================

# --- Qt 安装路径 ---
# 不同机器 Qt 路径不同，在这里设置后就不用每次 -DCMAKE_PREFIX_PATH=...
# set(CMAKE_PREFIX_PATH "C:/Qt/6.10.0/msvc2022_64" CACHE PATH "" FORCE)
# set(CMAKE_PREFIX_PATH "C:/Qt/5.15.2/msvc2019_64" CACHE PATH "" FORCE)

# --- 构建类型 ---
# if(NOT CMAKE_BUILD_TYPE)
#     set(CMAKE_BUILD_TYPE "Debug" CACHE STRING "" FORCE)
# endif()

# --- 测试 ---
# set(VE_BUILD_TEST ON CACHE BOOL "" FORCE)

# --- 模块开关 ---
# set(BUILD_CORE    ON  CACHE BOOL "" FORCE)
# set(BUILD_SERVICE ON  CACHE BOOL "" FORCE)
# set(BUILD_MAIN    OFF CACHE BOOL "" FORCE)

# --- 日志级别 ---
# set(LOG_MIN_FILE_LEVEL 2)   # 0=Debug, 1=Info, 2=Warning, 3=Error, 4=Critical

# --- 共享/静态库 ---
# set(BUILD_SHARED_LIBS OFF CACHE BOOL "" FORCE)

# --- Release 也生成调试符号（崩溃栈/定位源码行）---
# 默认 OFF；与 mxhelper cmake/compile.cmake 的 FORCE_DEBUG_INFO 行为一致（MSVC: /Zi + 链接 /DEBUG；GCC/Clang: -g）
# set(VE_FORCE_DEBUG_INFO ON CACHE BOOL "" FORCE)

# =============================================================================
# 本地三方库路径
# =============================================================================
# ve_find_package 优先使用此处的本地路径 (add_subdirectory)，
# 不设置则走 find_package → FetchContent 自动下载。
#
# 格式: set(VE_DEP_<PackageName> "<本地clone路径>" CACHE PATH "" FORCE)
#
# set(VE_DEP_nlohmann_json "D:/workspace/github/json"     CACHE PATH "" FORCE)
# set(VE_DEP_simdjson      "D:/workspace/github/simdjson"  CACHE PATH "" FORCE)
# set(VE_DEP_yaml-cpp      "D:/workspace/github/yaml-cpp"  CACHE PATH "" FORCE)
# set(VE_DEP_pugixml "D:/workspace/github/pugixml" CACHE PATH "" FORCE)
