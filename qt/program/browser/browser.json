{
  "ve": {
    "entry": {
      "verbose": false,
      "plugins": [
        { "path": "libveqt" },
        { "path": "libveqtbrowser" }
      ]
    },
    "core": {
      "priority": 0,
      "config": {
        "log": {
          "level": "info",
          "app": "veQtBrowser"
        },
        "rescue": {
          "enabled": true
        }
      }
    },
    "qt": {
      "priority": 5,
      "config": {
        "app_type": "gui",
        "attr": {
          "ShareOpenGLContexts": true,
          "Use96Dpi": false
        },
        "log": {
          "install_qt_message_handler": true,
          "bridge_imol_log_signals": true,
          "bridge_imol_log_export": true
        }
      }
    },
    "service": {
      "http": { "config": { "port": 8080 } },
      "ws": { "config": { "port": 8081 } },
      "terminal": { "config": { "port": 5061 } },
      "tcp_bin": { "enabled": false }
    }
  },
  "browser": {
    "config": {
      "static_root": "./web/",
      "http_port": 8080,
      "ws_port": 8081
    }
  }
}
