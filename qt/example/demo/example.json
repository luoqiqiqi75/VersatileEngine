{
  "verbose": true,
  "module": {
    "ve.core": {
      "priority": 0,
      "config": {
        "log": {
          "level": "info",
          "app": "veExample"
        },
        "rescue": {
          "enabled": true
        }
      }
    },
    "ve.qt": {
      "priority": 5,
      "config": {
        "attr": {
          "ShareOpenGLContexts": true,
          "Use96Dpi": false
        },
        "log": {
          "install_qt_message_handler": true,
          "bridge_imol_log_signals": true,
          "bridge_imol_log_export": true
        }
      }
    },
    "sensor": {},
    "processor": {},
    "dashboard": {},
    "ve.service.http": {
      "enabled": false
    },
    "ve.service.ws": {
      "enabled": false
    },
    "ve.service.tcp_bin": {
      "enabled": false
    },
    "ve.service.terminal": {
      "enabled": false
    }
  }
}
