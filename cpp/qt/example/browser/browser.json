{
  "verbose": false,
  "module": {
    "ve.core": {
      "priority": 0,
      "config": {
        "log": {
          "level": "info",
          "app": "veQtBrowser"
        },
        "rescue": {
          "enabled": true
        }
      }
    },
    "ve.qt": {
      "priority": 5,
      "config": {
        "attr": {
          "ShareOpenGLContexts": true,
          "Use96Dpi": false
        },
        "log": {
          "install_qt_message_handler": true,
          "bridge_imol_log_signals": true,
          "bridge_imol_log_export": true
        }
      }
    },
    "browser": {
      "config": {
        "static_root": "./web/",
        "http_port": 8080,
        "ws_port": 8081
      }
    },
    "ve.service.http": {
      "config": {
        "port": 8080
      }
    },
    "ve.service.ws": {
      "config": {
        "port": 8081
      }
    },
    "ve.service.terminal": {
      "config": {
        "port": 5061
      }
    },
    "ve.service.tcp_bin": {
      "enabled": false
    }
  }
}
